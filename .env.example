# Server
SERVER_ADDR=:8080
SERVER_API_TOKEN=change-me
MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/sensitive_agent?charset=utf8mb4&parseTime=True&loc=Local

# Ark/OpenAI-compatible chat
ARK_API_KEY=xxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_CHAT_MODEL=xxx
ARK_EMBEDDING_MODEL=xxx
# Backward-compatible chat model fallback, optional
ARK_ENDPOINT_ID=xxx

# Embedding provider. Use local Ollama bge-m3 by default when configured.
# Start Ollama first: ollama serve && ollama pull bge-m3
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_EMBED_MODEL=bge-m3

# Keyword extraction
# Windows defaults to a safe tokenizer fallback. Set GOJIEBA_MODE=force after installing a C/C++ toolchain to enable gojieba.
GOJIEBA_MODE=

# PaddleOCR PDF extraction API
# Replace these placeholders with your PaddleOCR HTTP endpoint and API key.
PADDLEOCR_API_URL=xxx
PADDLEOCR_API_KEY=xxx
